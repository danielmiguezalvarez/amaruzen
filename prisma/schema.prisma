// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// NextAuth required models
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// Core models
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  ALUMNO
  PROFESIONAL
}

enum DiaSemana {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
}

enum TipoConvenio {
  EQUIVALENTE
  EXCEPCIONAL
}

enum EstadoCambio {
  PENDIENTE
  APROBADO
  RECHAZADO
}

enum EstadoReserva {
  PENDIENTE
  APROBADA
  RECHAZADA
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null si usa OAuth
  role          Role      @default(ALUMNO)
  activo        Boolean   @default(true)
  notificaciones Boolean  @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  inscripciones Inscripcion[]
  cambios       Cambio[]
  reservas      Reserva[]
  ausencias     Ausencia[] @relation("AusenciaAlumno")
  ausenciasCreadas Ausencia[] @relation("AusenciaCreador")
  profesor      Profesor?
  invitacionesAcceso InvitacionAcceso[] @relation("InvitacionAccesoUser")
  invitacionesCreadas InvitacionAcceso[] @relation("InvitacionAccesoCreador")
}

model Sala {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  aforo       Int
  color       String?
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  horarios    Horario[]
  clases      Clase[]
  sesiones    Sesion[]
  reservas    Reserva[]
}

model Profesor {
  id        String   @id @default(cuid())
  nombre    String
  email     String?  @unique
  telefono  String?
  userId    String?  @unique
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  horarios  Horario[]
  clases    Clase[]
  sesiones  Sesion[]
  invitacionesAcceso InvitacionAcceso[]
}

model InvitacionAcceso {
  id          String    @id @default(cuid())
  email       String
  role        Role
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  userId      String?
  profesorId  String?
  createdById String
  createdAt   DateTime  @default(now())

  user        User?     @relation("InvitacionAccesoUser", fields: [userId], references: [id], onDelete: SetNull)
  profesor    Profesor? @relation(fields: [profesorId], references: [id], onDelete: SetNull)
  createdBy   User      @relation("InvitacionAccesoCreador", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([email, role, usedAt])
  @@index([expiresAt])
}

model TipoClase {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clases      Clase[]
}

model Clase {
  id          String     @id @default(cuid())
  nombre      String
  tipoClaseId String
  profesorId  String
  salaId      String
  aforo       Int
  recurrente  Boolean    @default(true)
  color       String?
  fechaInicio DateTime?  // null = sin límite inferior
  fechaFin    DateTime?  // null = indefinida; si se pone, la clase termina ese día
  activa      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tipoClase   TipoClase  @relation(fields: [tipoClaseId], references: [id])
  profesor    Profesor   @relation(fields: [profesorId], references: [id])
  sala        Sala       @relation(fields: [salaId], references: [id])

  horarios             Horario[]
  inscripciones        Inscripcion[]
  sesiones             Sesion[]
  conveniosComoClaseA  Convenio[]   @relation("ConvenioClaseA")
  conveniosComoClaseB  Convenio[]   @relation("ConvenioClaseB")
  reservas             Reserva[]
}

model Horario {
  id         String     @id @default(cuid())
  claseId    String
  profesorId String
  salaId     String
  diaSemana  DiaSemana?
  fecha      DateTime?
  horaInicio String
  horaFin    String
  aforo      Int
  activo     Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  clase      Clase      @relation(fields: [claseId], references: [id])
  profesor   Profesor   @relation(fields: [profesorId], references: [id])
  sala       Sala       @relation(fields: [salaId], references: [id])

  sesiones   Sesion[]
  inscripcionesHorarios InscripcionHorario[]
  ausencias  Ausencia[]

  @@index([claseId])
  @@index([salaId])
  @@index([profesorId])
  @@index([activo, fecha])
  @@index([activo, diaSemana])
}

model Sesion {
  id         String   @id @default(cuid())
  claseId    String
  horarioId  String
  profesorId String
  salaId     String
  fecha      DateTime // fecha concreta de la sesión
  horaInicio String   // permite sobrescribir si hay excepción
  horaFin    String
  aforo      Int      // copia del aforo en el momento de creación
  cancelada  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  clase      Clase    @relation(fields: [claseId], references: [id])
  horario    Horario  @relation(fields: [horarioId], references: [id])
  profesor   Profesor @relation(fields: [profesorId], references: [id])
  sala       Sala     @relation(fields: [salaId], references: [id])

  cambiosComoOrigen  Cambio[] @relation("CambioOrigen")
  cambiosComoDestino Cambio[] @relation("CambioDestino")

  @@unique([horarioId, fecha])
  @@index([fecha])
  @@index([claseId, fecha])
  @@index([profesorId, fecha])
  @@index([salaId, fecha])
}

model Inscripcion {
  id        String   @id @default(cuid())
  userId    String
  claseId   String
  numClases Int      @default(1)
  activa    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clase     Clase    @relation(fields: [claseId], references: [id])
  horarios  InscripcionHorario[]

  @@unique([userId, claseId])
}

model InscripcionHorario {
  id            String      @id @default(cuid())
  inscripcionId String
  horarioId     String
  activa        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  inscripcion   Inscripcion @relation(fields: [inscripcionId], references: [id], onDelete: Cascade)
  horario       Horario     @relation(fields: [horarioId], references: [id])

  @@unique([inscripcionId, horarioId])
  @@index([horarioId])
  @@index([horarioId, activa])
}

model Convenio {
  id                 String       @id @default(cuid())
  claseAId           String
  claseBId           String
  tipo               TipoConvenio
  limiteMensual      Int          // número de cambios permitidos por mes
  requiereAprobacion Boolean      @default(false) // aplica solo a EXCEPCIONAL
  activo             Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  claseA             Clase        @relation("ConvenioClaseA", fields: [claseAId], references: [id])
  claseB             Clase        @relation("ConvenioClaseB", fields: [claseBId], references: [id])

  cambios            Cambio[]

  @@unique([claseAId, claseBId])
}

model Cambio {
  id              String       @id @default(cuid())
  userId          String
  sesionOrigenId  String
  sesionDestinoId String
  convenioId      String?      // null si es cambio a la misma clase otro horario
  estado          EstadoCambio @default(PENDIENTE)
  forzado         Boolean      @default(false)
  nota            String?      // mensaje opcional del alumno
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sesionOrigen    Sesion       @relation("CambioOrigen", fields: [sesionOrigenId], references: [id])
  sesionDestino   Sesion       @relation("CambioDestino", fields: [sesionDestinoId], references: [id])
  convenio        Convenio?    @relation(fields: [convenioId], references: [id])

  @@index([estado])
  @@index([sesionOrigenId])
  @@index([sesionDestinoId])
  @@index([estado, sesionOrigenId])
  @@index([estado, sesionDestinoId])
}

model Reserva {
  id            String        @id @default(cuid())
  salaId        String
  profesionalId String
  claseId       String?
  fecha         DateTime
  horaInicio    String
  horaFin       String
  motivo        String?
  estado        EstadoReserva @default(PENDIENTE)
  notas         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sala          Sala          @relation(fields: [salaId], references: [id])
  profesional   User          @relation(fields: [profesionalId], references: [id])
  clase         Clase?        @relation(fields: [claseId], references: [id])

  @@index([estado, fecha])
  @@index([salaId, fecha])
}

model Ausencia {
  id          String   @id @default(cuid())
  userId      String
  horarioId   String
  fecha       DateTime
  motivo      String?
  creadoPorId String
  createdAt   DateTime @default(now())

  user        User     @relation("AusenciaAlumno", fields: [userId], references: [id], onDelete: Cascade)
  horario     Horario  @relation(fields: [horarioId], references: [id])
  creadoPor   User     @relation("AusenciaCreador", fields: [creadoPorId], references: [id])

  @@unique([userId, horarioId, fecha])
  @@index([horarioId, fecha])
}
